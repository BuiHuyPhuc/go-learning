# Binary cho chương trình và plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Test binary (sinh ra khi dùng `go test -c`)
*.test

# Kết quả đo độ bao phủ code (Coverage)
*.out
*.coverprofile
coverage.txt
profile.cov

# Dependency directories
# Thông thường không nên commit vendor/ trừ khi dự án yêu cầu đặc biệt
vendor/

# Go workspace file
go.work
go.work.sum

# Các file biến môi trường (Chứa thông tin nhạy cảm)
.env
*.env
.env.local

# Các thư mục tạm và log
tmp/
temp/
logs/
*.log

# Cấu hình của VS Code (Nên ignore để mỗi người dùng cấu hình riêng)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Cấu hình của JetBrains (GoLand)
.idea/

# File rác hệ điều hành
.DS_Store
Thumbs.db
